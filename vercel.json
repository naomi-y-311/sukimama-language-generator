{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/generate.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 60
      }
    },
    {
      "src": "api/todos.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/generate",
      "dest": "/api/generate.js"
    },
    {
      "src": "/api/todos",
      "dest": "/api/todos.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/songs-todo",
      "dest": "/public/todo.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}
